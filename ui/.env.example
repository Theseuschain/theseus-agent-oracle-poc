# EVM endpoint. Theseus exposes Ethereum-compatible JSON-RPC via the
# `eth-rpc` proxy (PolkaVM under the hood). Default 8545 to match the
# pattern in github.com/Theseuschain/theseus-layerzero-evm.
NEXT_PUBLIC_EVM_RPC=http://127.0.0.1:8545
NEXT_PUBLIC_CHAIN_ID=420420420

# Substrate endpoint (server-side only — not exposed to the browser)
THESEUS_WS=ws://127.0.0.1:9944

# Admin signing seed for tamper / reset extrinsics. Dev: //Alice.
# Server-side only.
ADMIN_SEED=//Alice

# Deployment addresses. Filled in by scripts/setup_demo.sh.
NEXT_PUBLIC_AGENT_PRICE_FEED=
NEXT_PUBLIC_POOL=
NEXT_PUBLIC_WETH=
NEXT_PUBLIC_USDC=
NEXT_PUBLIC_AGENT_ID=

# Optional: WalletConnect project ID for the Connect button. Get one at
# https://cloud.walletconnect.com if you want WC-compatible wallets.
NEXT_PUBLIC_WC_PROJECT_ID=

# DeepSeek API key for the LLM-backed agent. When unset, the "DeepSeek" mode
# in the UI will return 503 and the demo falls back to the rule-based agent.
# Server-side only. Mark as Sensitive on Vercel.
DEEPSEEK_API_KEY=

# Optional: keyed Ethereum mainnet RPC for the Uniswap V3 reader. When unset,
# falls back to a chain of public RPCs (blastapi → ankr → cloudflare → llama).
MAINNET_RPC=

# --- Launch sniper agent (paper-trading on Base Sepolia) ---
# Anthropic API key for the Launch Sniper evaluator (Claude Haiku 4.5).
# Server-side only. Mark as Sensitive on Vercel.
ANTHROPIC_API_KEY=

# Private key (0x-prefixed hex) for the Launch Sniper agent EOA. Signs
# tick() calls on the LaunchSniperFund contract on Base Sepolia. Same
# centralized agent EOA as SovereignFund. Server-side only. Sensitive.
AGENT_PRIVATE_KEY=

# Optional: keyed Base mainnet RPC for the launch indexer's eth_getLogs
# scans. When unset, falls back to https://mainnet.base.org.
BASE_MAINNET_RPC=

# Optional: keyed Base Sepolia RPC for the executor's tick() calls. When
# unset, falls back to https://sepolia.base.org.
BASE_SEPOLIA_RPC=

# Vercel Blob credential for publishing reasoning blobs. The executor
# writes the full dossier + decision JSON to blob storage under
# `launch-sniper/<reasonHash>.json` and the on-chain reasonHash points
# at it. Get the token from Vercel: Project → Storage → Blob → "Create
# new token". When unset, blobs aren't published but ticks still post.
BLOB_READ_WRITE_TOKEN=

# Public base URL of the Vercel Blob store. Used by the viewer to build
# blob URLs from on-chain reason hashes without a separate lookup.
# Format: https://<store-id>.public.blob.vercel-storage.com
BLOB_PUBLIC_BASE_URL=
