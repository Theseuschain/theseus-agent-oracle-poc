# Local Theseus node endpoints. Default values match `theseus-node --dev`.
THESEUS_EVM_RPC=http://127.0.0.1:9933
THESEUS_WS=ws://127.0.0.1:9944

# Private key (0x-prefixed hex) the deployer + demo user signs with on the
# Theseus EVM. For local dev, any 32-byte hex works as long as the
# corresponding address has been pre-funded by `theseus-node --dev`.
DEPLOYER_KEY=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d

# CLI's signing key (same key, different name) for `op deposit`, `op borrow`, etc.
OP_PRIVATE_KEY=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d
